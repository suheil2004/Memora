# Runtime
MEMORA_ENV=development
MEMORA_LOG_LEVEL=INFO
MEMORA_DATABASE_URL=sqlite:///./memora.sqlite3
MEMORA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MEMORA_LOCAL_TOKEN=
MEMORA_USER_ID=demo-user

# Configure only when an embedding implementation is selected.
MEMORA_EMBEDDING_PROVIDER=local
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MEMORA_SYNTHESIS_PROVIDER=deterministic
MEMORA_SYNTHESIS_MODEL=gpt-5.6-luna
MEMORA_PDF_MAX_FILES=5
MEMORA_PDF_MAX_FILE_BYTES=20971520
MEMORA_PDF_MAX_TOTAL_BYTES=52428800
MEMORA_PDF_MAX_PAGES=300
MEMORA_PDF_MAX_TEXT_CHARS=2000000
MEMORA_PDF_MAX_CHUNKS=1000

# ChatGPT exports containing opaque assets can be much larger. Keep conservative
# defaults unless deliberately importing a trusted local export.
MEMORA_CHATGPT_MAX_UPLOAD_BYTES=262144000
MEMORA_CHATGPT_MAX_UNCOMPRESSED_BYTES=209715200

# Retrieval limits
MEMORA_CHUNK_SIZE_TOKENS=400
MEMORA_CHUNK_OVERLAP_TOKENS=50
MEMORA_RETRIEVAL_LIMIT=8
MEMORA_CONTEXT_MAX_CHARS=6000
# Required for semantic/unknown providers after running scripts.calibrate_relevance.
MEMORA_RELEVANCE_MIN_SIMILARITY=
MEMORA_RETRIEVAL_RATE_LIMIT=60
MEMORA_RETRIEVAL_RATE_WINDOW_SECONDS=60
MEMORA_IMPORT_RATE_LIMIT=10
MEMORA_IMPORT_RATE_WINDOW_SECONDS=600
