# Runtime
MEMORA_ENV=development
MEMORA_LOG_LEVEL=INFO
MEMORA_DATABASE_URL=sqlite:///./memora.sqlite3
MEMORA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MEMORA_LOCAL_TOKEN=
MEMORA_USER_ID=demo-user

# Configure only when an embedding implementation is selected.
MEMORA_EMBEDDING_PROVIDER=local
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval limits
MEMORA_CHUNK_SIZE_TOKENS=400
MEMORA_CHUNK_OVERLAP_TOKENS=50
MEMORA_RETRIEVAL_LIMIT=8
MEMORA_CONTEXT_MAX_CHARS=6000
MEMORA_RETRIEVAL_RATE_LIMIT=60
MEMORA_RETRIEVAL_RATE_WINDOW_SECONDS=60
MEMORA_IMPORT_RATE_LIMIT=10
MEMORA_IMPORT_RATE_WINDOW_SECONDS=600
